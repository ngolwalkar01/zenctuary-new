{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zenctuary/zen-soul-kitchen-menu",
	"title": "Zen Soul Kitchen Menu",
	"category": "widgets",
	"icon": "food",
	"description": "Display WooCommerce products grouped by category with Drinks and Food tag filters.",
	"keywords": [ "woocommerce", "menu", "products", "food", "drinks" ],
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Soul Kitchen Menu"
		},
		"activeFilter": {
			"type": "string",
			"default": "drinks"
		},
		"drinksTagSlug": {
			"type": "string",
			"default": "drinks"
		},
		"foodTagSlug": {
			"type": "string",
			"default": "food"
		},
		"categorySettings": {
			"type": "object",
			"default": {}
		},
		"sectionPadding": {
			"type": "object",
			"default": { "top": "0px", "right": "0px", "bottom": "0px", "left": "0px" }
		},
		"sectionMargin": {
			"type": "object",
			"default": { "top": "0px", "right": "0px", "bottom": "0px", "left": "0px" }
		},
		"headingColor": {
			"type": "string",
			"default": ""
		},
		"headingFontSize": {
			"type": "string",
			"default": ""
		},
		"headingFontWeight": {
			"type": "string",
			"default": "700"
		},
		"headingAlignment": {
			"type": "string",
			"default": "left"
		},
		"selectedTags": {
			"type": "array",
			"default": []
		},
		"buttonStyles": {
			"type": "object",
			"default": {
				"normal": {
					"backgroundColor": "",
					"textColor": "",
					"fontWeight": "400",
					"borderColor": "",
					"borderWidth": "1px",
					"borderRadius": "25px"
				},
				"active": {
					"backgroundColor": "#d9b35c",
					"textColor": "#000000",
					"borderColor": "#d9b35c"
				}
			}
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ]
	},
	"textdomain": "zenctuary",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./style-index.css",
	"render": "file:./render.php"
}
