{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/product-feature-cards",
  "version": "1.0.0",
  "title": "Product Feature Cards",
  "category": "design",
  "icon": "cart",
  "description": "Premium WooCommerce product cards with zencoin strip, session meta, CTA, and expandable What to Expect content.",
  "keywords": ["zenctuary", "woocommerce", "products", "cards", "zencoins"],
  "textdomain": "zenctuary",
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "attributes": {
    "queryMode": { "type": "string", "default": "taxonomy" },
    "productTaxonomy": { "type": "string", "default": "product_cat" },
    "termIds": { "type": "array", "default": [] },
    "productsToShow": { "type": "number", "default": 6 },
    "orderBy": { "type": "string", "default": "date" },
    "order": { "type": "string", "default": "DESC" },
    "offset": { "type": "number", "default": 0 },
    "manualProductIds": { "type": "array", "default": [] },
    "excludeProductIds": { "type": "array", "default": [] },
    "hideOutOfStock": { "type": "boolean", "default": true },
    "onlyFeaturedProducts": { "type": "boolean", "default": false },
    "sectionBackgroundColor": { "type": "string", "default": "#3f3d3d" },
    "sectionTextColor": { "type": "string", "default": "#f6f2ea" },
    "sectionMaxWidth": { "type": "number", "default": 1600 },
    "sectionPaddingTop": { "type": "number", "default": 88 },
    "sectionPaddingBottom": { "type": "number", "default": 88 },
    "sectionPaddingLeft": { "type": "number", "default": 40 },
    "sectionPaddingRight": { "type": "number", "default": 40 },
    "sectionMarginTop": { "type": "number", "default": 0 },
    "sectionMarginBottom": { "type": "number", "default": 0 },
    "sectionHeading": { "type": "string", "default": "" },
    "sectionIntro": { "type": "string", "default": "" },
    "headingColor": { "type": "string", "default": "#d8b354" },
    "headingFontSize": { "type": "number", "default": 36 },
    "headingFontWeight": { "type": "string", "default": "700" },
    "headingTextTransform": { "type": "string", "default": "uppercase" },
    "introColor": { "type": "string", "default": "#f6f2ea" },
    "introFontSize": { "type": "number", "default": 18 },
    "introLineHeight": { "type": "number", "default": 1.6 },
    "headingBottomSpacing": { "type": "number", "default": 18 },
    "introBottomSpacing": { "type": "number", "default": 38 },
    "contentAlignment": { "type": "string", "default": "start" },
    "slidesPerViewDesktop": { "type": "number", "default": 2 },
    "slidesPerViewTablet": { "type": "number", "default": 1.35 },
    "slidesPerViewMobile": { "type": "number", "default": 1.08 },
    "cardWidth": { "type": "number", "default": 620 },
    "cardHeight": { "type": "number", "default": 980 },
    "cardHeightTablet": { "type": "number", "default": 860 },
    "cardHeightMobile": { "type": "number", "default": 760 },
    "cardMaxWidth": { "type": "number", "default": 680 },
    "cardGapDesktop": { "type": "number", "default": 36 },
    "cardGapTablet": { "type": "number", "default": 26 },
    "cardGapMobile": { "type": "number", "default": 18 },
    "showArrows": { "type": "boolean", "default": true },
    "enableDrag": { "type": "boolean", "default": true },
    "enableLoop": { "type": "boolean", "default": false },
    "autoplay": { "type": "boolean", "default": false },
    "autoplaySpeed": { "type": "number", "default": 4500 },
    "cardBorderRadius": { "type": "number", "default": 28 },
    "cardBorderColor": { "type": "string", "default": "rgba(246, 242, 234, 0.58)" },
    "cardBorderWidth": { "type": "number", "default": 2 },
    "cardShadow": { "type": "string", "default": "none" },
    "cardOverlayColor": { "type": "string", "default": "#20201f" },
    "cardOverlayOpacity": { "type": "number", "default": 0.4 },
    "cardPaddingTop": { "type": "number", "default": 0 },
    "cardPaddingRight": { "type": "number", "default": 0 },
    "cardPaddingBottom": { "type": "number", "default": 0 },
    "cardPaddingLeft": { "type": "number", "default": 0 },
    "topStripHeight": { "type": "number", "default": 108 },
    "topStripBackgroundColor": { "type": "string", "default": "#3f3d3d" },
    "topStripPaddingX": { "type": "number", "default": 30 },
    "topStripPaddingY": { "type": "number", "default": 18 },
    "topStripAlignment": { "type": "string", "default": "center" },
    "zencoinLabel": { "type": "string", "default": "ZENCOINS:" },
    "zencoinSource": { "type": "string", "default": "custom" },
    "zencoinLabelColor": { "type": "string", "default": "#d8b354" },
    "zencoinLabelFontSize": { "type": "number", "default": 24 },
    "zencoinLabelFontWeight": { "type": "string", "default": "700" },
    "zencoinValueColor": { "type": "string", "default": "#3f3d3d" },
    "zencoinValueFontSize": { "type": "number", "default": 22 },
    "zencoinValueFontWeight": { "type": "string", "default": "700" },
    "zencoinBadgeSize": { "type": "number", "default": 56 },
    "zencoinBadgeBorderWidth": { "type": "number", "default": 2 },
    "zencoinBadgeBorderColor": { "type": "string", "default": "#d8b354" },
    "zencoinBadgeBackgroundColor": { "type": "string", "default": "#d8b354" },
    "zencoinGap": { "type": "number", "default": 16 },
    "contentPaddingX": { "type": "number", "default": 52 },
    "contentPaddingTop": { "type": "number", "default": 50 },
    "contentPaddingBottom": { "type": "number", "default": 32 },
    "titleColor": { "type": "string", "default": "#ffffff" },
    "titleFontSize": { "type": "number", "default": 58 },
    "titleFontWeight": { "type": "string", "default": "700" },
    "titleLineHeight": { "type": "number", "default": 1.06 },
    "titleLetterSpacing": { "type": "number", "default": 0 },
    "titleTextTransform": { "type": "string", "default": "uppercase" },
    "titleBottomSpacing": { "type": "number", "default": 28 },
    "showSessionIcon": { "type": "boolean", "default": true },
    "sessionIconSize": { "type": "number", "default": 18 },
    "sessionIconColor": { "type": "string", "default": "#3f3d3d" },
    "sessionBadgeBackground": { "type": "string", "default": "#d8b354" },
    "sessionTextColor": { "type": "string", "default": "#f6f2ea" },
    "sessionFontSize": { "type": "number", "default": 18 },
    "sessionFontWeight": { "type": "string", "default": "400" },
    "sessionGap": { "type": "number", "default": 12 },
    "sessionBottomSpacing": { "type": "number", "default": 28 },
    "excerptColor": { "type": "string", "default": "#f6f2ea" },
    "excerptFontSize": { "type": "number", "default": 19 },
    "excerptLineHeight": { "type": "number", "default": 1.5 },
    "excerptMaxWidth": { "type": "number", "default": 470 },
    "excerptBottomSpacing": { "type": "number", "default": 32 },
    "ctaLabel": { "type": "string", "default": "Book Now" },
    "ctaTextColor": { "type": "string", "default": "#d8b354" },
    "ctaBackgroundColor": { "type": "string", "default": "#3f3d3d" },
    "ctaBorderColor": { "type": "string", "default": "#d8b354" },
    "ctaBorderWidth": { "type": "number", "default": 2 },
    "ctaBorderRadius": { "type": "number", "default": 999 },
    "ctaFontSize": { "type": "number", "default": 18 },
    "ctaFontWeight": { "type": "string", "default": "700" },
    "ctaPaddingY": { "type": "number", "default": 18 },
    "ctaPaddingX": { "type": "number", "default": 42 },
    "ctaShowIcon": { "type": "boolean", "default": true },
    "ctaIconPosition": { "type": "string", "default": "right" },
    "ctaTopSpacing": { "type": "number", "default": 0 },
    "dividerColor": { "type": "string", "default": "rgba(246, 242, 234, 0.7)" },
    "dividerThickness": { "type": "number", "default": 2 },
    "dividerTopSpacing": { "type": "number", "default": 40 },
    "dividerBottomSpacing": { "type": "number", "default": 22 },
    "expandLabel": { "type": "string", "default": "What to expect" },
    "expandLabelColor": { "type": "string", "default": "#f6f2ea" },
    "expandLabelFontSize": { "type": "number", "default": 18 },
    "expandLabelFontWeight": { "type": "string", "default": "700" },
    "expandIconSize": { "type": "number", "default": 28 },
    "expandIconColor": { "type": "string", "default": "#f6f2ea" },
    "expandRowPaddingY": { "type": "number", "default": 8 },
    "expandedContentColor": { "type": "string", "default": "#f6f2ea" },
    "expandedContentFontSize": { "type": "number", "default": 16 },
    "expandedContentLineHeight": { "type": "number", "default": 1.6 },
    "expandedContentSpacingTop": { "type": "number", "default": 18 },
    "expandedContentMaxHeight": { "type": "number", "default": 260 },
    "allowMultipleExpanded": { "type": "boolean", "default": true },
    "previewState": { "type": "string", "default": "collapsed" }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
