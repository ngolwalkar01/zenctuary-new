{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/zen-team-intro",
  "version": "1.0.0",
  "title": "Zen Team Intro",
  "category": "design",
  "icon": "id-alt",
  "description": "Two-column team intro with image overlay name/job title and rich text content.",
  "keywords": ["zenctuary", "team", "intro", "profile"],
  "textdomain": "zenctuary",
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"]
  },
  "attributes": {
    "imageId": { "type": "number" },
    "imageUrl": { "type": "string", "default": "" },
    "imageAlt": { "type": "string", "default": "" },
    "nameText": { "type": "string", "source": "html", "selector": ".zti__name", "default": "SHERVIN ZAMANI" },
    "roleText": { "type": "string", "source": "html", "selector": ".zti__role", "default": "FOUNDER & CEO" },
    "contentTitle": { "type": "string", "source": "html", "selector": ".zti__content-title", "default": "COOLA CHEF" },
    "contentBody": { "type": "string", "source": "html", "selector": ".zti__content-body", "default": "<p>We founded \u014cHIA because we believe that inner peace is the most powerful force in the universe to cultivate change.</p><p>As former strategic consultants and managers in fast-paced corporate and startup environments, we often felt overwhelmed, stressed, and unfulfilled.</p>" },
    "sectionBackgroundColor": { "type": "string", "default": "#3f3d3d" },
    "sectionTextColor": { "type": "string", "default": "#f6f2ea" },
    "sectionPaddingTop": { "type": "number", "default": 80 },
    "sectionPaddingRight": { "type": "number", "default": 40 },
    "sectionPaddingBottom": { "type": "number", "default": 80 },
    "sectionPaddingLeft": { "type": "number", "default": 40 },
    "sectionMaxWidth": { "type": "number", "default": 1500 },
    "columnGap": { "type": "number", "default": 70 },
    "imageWidth": { "type": "number", "default": 740 },
    "imageMinHeight": { "type": "number", "default": 650 },
    "imageBorderRadius": { "type": "number", "default": 32 },
    "imageOverlayPaddingTop": { "type": "number", "default": 28 },
    "imageOverlayPaddingRight": { "type": "number", "default": 28 },
    "imageOverlayPaddingBottom": { "type": "number", "default": 28 },
    "imageOverlayPaddingLeft": { "type": "number", "default": 28 },
    "nameColor": { "type": "string", "default": "#ffffff" },
    "nameFontSize": { "type": "number", "default": 64 },
    "nameFontWeight": { "type": "string", "default": "700" },
    "nameLineHeight": { "type": "number", "default": 1.02 },
    "nameLetterSpacing": { "type": "number", "default": 0 },
    "nameTextTransform": { "type": "string", "default": "uppercase" },
    "nameHorizontal": { "type": "string", "default": "left" },
    "nameVertical": { "type": "string", "default": "top" },
    "nameOffsetX": { "type": "number", "default": 0 },
    "nameOffsetY": { "type": "number", "default": 0 },
    "roleColor": { "type": "string", "default": "#ffffff" },
    "roleFontSize": { "type": "number", "default": 34 },
    "roleFontWeight": { "type": "string", "default": "400" },
    "roleLineHeight": { "type": "number", "default": 1.1 },
    "roleLetterSpacing": { "type": "number", "default": 0 },
    "roleTextTransform": { "type": "string", "default": "uppercase" },
    "roleHorizontal": { "type": "string", "default": "left" },
    "roleVertical": { "type": "string", "default": "bottom" },
    "roleOffsetX": { "type": "number", "default": 0 },
    "roleOffsetY": { "type": "number", "default": 0 },
    "contentTitleColor": { "type": "string", "default": "#d8b354" },
    "contentTitleFontSize": { "type": "number", "default": 64 },
    "contentTitleFontWeight": { "type": "string", "default": "700" },
    "contentTitleLineHeight": { "type": "number", "default": 1.05 },
    "contentTitleLetterSpacing": { "type": "number", "default": 0 },
    "contentTitleTextTransform": { "type": "string", "default": "uppercase" },
    "contentTitleBottomSpacing": { "type": "number", "default": 34 },
    "contentBodyColor": { "type": "string", "default": "#f6f2ea" },
    "contentBodyFontSize": { "type": "number", "default": 24 },
    "contentBodyFontWeight": { "type": "string", "default": "400" },
    "contentBodyLineHeight": { "type": "number", "default": 1.6 },
    "contentBodyLetterSpacing": { "type": "number", "default": 0 },
    "contentBodyMaxWidth": { "type": "number", "default": 760 }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css"
}
