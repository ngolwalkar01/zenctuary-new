{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/contact-map",
  "version": "1.0.0",
  "title": "Contact Map",
  "category": "design",
  "icon": "location-alt",
  "description": "Displays a split layout with a map, a side image, and contact information.",
  "attributes": {
    "mapEmbedUrl": {
      "type": "string",
      "default": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2428.847525381881!2d13.4312845!3d52.4939764!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47a84e491c1b1811%3A0xe53ccac6f83196ed!2sReichenberger%20Str.%2080%2C%2010999%20Berlin%2C%20Germany!5e0!3m2!1sen!2sde!4v1712211902030!5m2!1sen!2sde"
    },
    "imageUrl": {
      "type": "string"
    },
    "imageId": {
      "type": "number"
    },
    "imageAlt": {
      "type": "string",
      "default": "Buddha Statue"
    },
    "logoUrl": {
      "type": "string"
    },
    "logoId": {
      "type": "number"
    },
    "logoAlt": {
      "type": "string",
      "default": "Zenctuary Logo"
    },
    "schedule": {
      "type": "string",
      "default": "MO-FR: 09:00-22:00"
    },
    "address": {
      "type": "string",
      "default": "Reichenberger Straße 80<br>10999 Berlin"
    },
    "email": {
      "type": "string",
      "default": "contact@company.com"
    },
    "phone": {
      "type": "string",
      "default": "+49 123 456 789"
    }
  },
  "supports": {
    "html": false,
    "align": ["full"]
  },
  "textdomain": "zenctuary",
  "editorScript": "file:./index.js"
}
