{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/zen-coca-chef",
  "version": "1.0.0",
  "title": "Zen-Coca-Chef",
  "category": "design",
  "icon": "id-alt",
  "description": "A premium profile feature section with image overlay text and rich content column.",
  "keywords": [
    "zenctuary",
    "profile",
    "chef",
    "feature"
