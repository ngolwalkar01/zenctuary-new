    },
    "paragraphTwoColor": {
      "type": "string",
      "default": "#f2eee4"
    },
    "paragraphTwoFontSize": {
      "type": "number",
      "default": 21
    },
    "paragraphTwoFontWeight": {
      "type": "string",
      "default": "400"
    },
    "paragraphTwoLineHeight": {
      "type": "number",
      "default": 1.45
    },
    "paragraphTwoMargin": {
      "type": "object",
      "default": {
        "top": "0px",
        "right": "0px",
        "bottom": "0px",
        "left": "0px"
      }
    }
