{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/premium-edge-peek-carousel",
  "version": "1.0.0",
  "title": "Premium Edge Peek Carousel",
  "category": "design",
  "icon": "images-alt2",
  "description": "A premium editorial card carousel with 3 full cards and a partial edge-peek card.",
  "keywords": [
    "carousel",
    "swiper",
    "cards",
    "slider",
    "editorial"
  ],
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Explore What Moves You"
    },
    "subheading": {
      "type": "string",
      "default": "Curated classes and rituals designed to keep the strip in motion."
    },
    "contentMaxWidth": {
      "type": "number",
      "default": 1320
    },
    "backgroundColor": {
      "type": "string",
      "default": "#f4efe7"
    },
    "headingMaxWidth": {
      "type": "number",
      "default": 760
    },
    "headingFontSize": {
      "type": "string",
      "default": "clamp(2rem, 4vw, 3.75rem)"
    },
    "headingFontWeight": {
      "type": "string",
      "default": "700"
    },
    "headingLineHeight": {
      "type": "string",
      "default": "0.98"
    },
    "headingColor": {
      "type": "string",
      "default": "#171717"
    },
    "sectionPadding": {
      "type": "object",
      "default": {
        "top": "72px",
        "right": "24px",
        "bottom": "72px",
        "left": "24px"
      }
    },
    "gap": {
      "type": "number",
      "default": 24
    },
    "desktopCards": {
      "type": "number",
      "default": 3
    },
    "tabletCards": {
      "type": "number",
      "default": 2
    },
    "mobileCards": {
      "type": "number",
      "default": 1
    },
    "edgePeekDesktop": {
      "type": "number",
      "default": 20
    },
    "edgePeekTablet": {
      "type": "number",
      "default": 20
    },
    "edgePeekMobile": {
      "type": "number",
      "default": 20
    },
    "leftStartOffsetDesktop": {
      "type": "number",
      "default": 80
    },
    "leftStartOffsetTablet": {
      "type": "number",
      "default": 48
    },
    "leftStartOffsetMobile": {
      "type": "number",
      "default": 20
    },
    "cardWidthScaleDesktop": {
      "type": "number",
      "default": 100
    },
    "cardWidthScaleTablet": {
      "type": "number",
      "default": 100
    },
    "cardWidthScaleMobile": {
      "type": "number",
      "default": 100
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "autoplayDelay": {
      "type": "number",
      "default": 4000
    },
    "transitionSpeed": {
      "type": "number",
      "default": 450
    },
    "showPagination": {
      "type": "boolean",
      "default": true
    },
    "cardBorderRadius": {
      "type": "number",
      "default": 20
    },
    "cardContentPadding": {
      "type": "number",
      "default": 24
    },
    "cardTitleFontSize": {
      "type": "string",
      "default": "clamp(1.5rem, 2.4vw, 2rem)"
    },
    "cardTitleFontWeight": {
      "type": "string",
      "default": "700"
    },
    "cardTitleLineHeight": {
      "type": "string",
      "default": "1.04"
    },
    "cardTitleColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "cardBodyFontSize": {
      "type": "string",
      "default": "1rem"
    },
    "cardBodyFontWeight": {
      "type": "string",
      "default": "400"
    },
    "cardBodyLineHeight": {
      "type": "string",
      "default": "1.5"
    },
    "cardBodyColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "cardTextUppercase": {
      "type": "boolean",
      "default": true
    },
    "dotsFontSize": {
      "type": "string",
      "default": "1.35rem"
    },
    "dotsLetterSpacing": {
      "type": "string",
      "default": "0.22em"
    },
    "dotsColor": {
      "type": "string",
      "default": "rgba(255, 255, 255, 0.86)"
    },
    "buttonFontSize": {
      "type": "string",
      "default": "0.95rem"
    },
    "buttonFontWeight": {
      "type": "string",
      "default": "600"
    },
    "buttonLineHeight": {
      "type": "string",
      "default": "1.2"
    },
    "buttonTextColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "buttonBackgroundColor": {
      "type": "string",
      "default": "rgba(255, 255, 255, 0.16)"
    },
    "buttonBorderColor": {
      "type": "string",
      "default": "rgba(255, 255, 255, 0.38)"
    },
    "buttonBorderWidth": {
      "type": "number",
      "default": 1
    },
    "buttonBorderRadius": {
      "type": "string",
      "default": "999px"
    },
    "buttonWidth": {
      "type": "string",
      "default": "fit-content"
    },
    "buttonPadding": {
      "type": "object",
      "default": {
        "top": "13px",
        "right": "20px",
        "bottom": "13px",
        "left": "20px"
      }
    },
    "buttonShowIcon": {
      "type": "boolean",
      "default": true
    },
    "buttonIconPosition": {
      "type": "string",
      "default": "right"
    },
    "navButtonSize": {
      "type": "number",
      "default": 54
    },
    "navIconSize": {
      "type": "number",
      "default": 20
    },
    "navBorderWidth": {
      "type": "number",
      "default": 1
    },
    "navBorderRadius": {
      "type": "string",
      "default": "999px"
    },
    "navBorderColor": {
      "type": "string",
      "default": "rgba(23, 23, 23, 0.16)"
    },
    "navBackgroundColor": {
      "type": "string",
      "default": "rgba(255, 255, 255, 0.78)"
    },
    "navIconColor": {
      "type": "string",
      "default": "#171717"
    },
    "navHoverBackgroundColor": {
      "type": "string",
      "default": "#171717"
    },
    "navHoverIconColor": {
      "type": "string",
      "default": "#f4efe7"
    },
    "navIconSet": {
      "type": "string",
      "default": "line-arrow"
    },
    "cards": {
      "type": "array",
      "default": [
        {
          "imageId": 0,
          "imageUrl": "",
          "showOverlay": true,
          "overlayColor": "#1f1d1a",
          "overlayOpacity": 0.48,
          "title": "Classes",
          "items": [
            "Yoga",
            "Breathwork",
            "Meditation"
          ],
          "showDots": true,
          "dotsText": "...",
          "buttonText": "View Classes",
          "buttonUrl": "#",
          "openInNewTab": false
        },
        {
          "imageId": 0,
          "imageUrl": "",
          "showOverlay": true,
          "overlayColor": "#16181d",
          "overlayOpacity": 0.46,
          "title": "Retreats",
          "items": [
            "Weekend Immersions",
            "Sound Journeys",
            "Reset Rituals"
          ],
          "showDots": true,
          "dotsText": "...",
          "buttonText": "See Retreats",
          "buttonUrl": "#",
          "openInNewTab": false
        },
        {
          "imageId": 0,
          "imageUrl": "",
          "showOverlay": true,
          "overlayColor": "#221c19",
          "overlayOpacity": 0.45,
          "title": "Memberships",
          "items": [
            "Studio Access",
            "Recovery Suites",
            "Private Sessions"
          ],
          "showDots": true,
          "dotsText": "...",
          "buttonText": "Explore Memberships",
          "buttonUrl": "#",
          "openInNewTab": false
        },
        {
          "imageId": 0,
          "imageUrl": "",
          "showOverlay": true,
          "overlayColor": "#13161a",
          "overlayOpacity": 0.5,
          "title": "Events",
          "items": [
            "Sunrise Gatherings",
            "Teacher Talks",
            "Community Nights"
          ],
          "showDots": true,
          "dotsText": "...",
          "buttonText": "Browse Events",
          "buttonUrl": "#",
          "openInNewTab": false
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "zenctuary",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "style": [
    "file:./index.css",
    "file:./style-index.css"
  ],
  "editorStyle": [
    "file:./index.css",
    "file:./style-index.css"
  ]
}