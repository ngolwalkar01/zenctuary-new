{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/session-phases",
  "title": "Zenctuary Session Phases",
  "category": "design",
  "icon": "columns",
  "description": "Session phases / steps cards row with full typography and layout control.",
  "keywords": [
    "session",
    "phases",
    "steps",
    "cards",
    "grid"
  ],
  "textdomain": "zenctuary",
  "attributes": {
    "cardsData": {
      "type": "string",
      "default": ""
    },
    "align": {
      "type": "string",
      "default": "full"
    },
    "sectionBgColor": {
      "type": "string",
      "default": "#3a3b38"
    },
    "sectionPaddingTop": {
      "type": "number",
      "default": 80
    },
    "sectionPaddingBottom": {
      "type": "number",
      "default": 80
    },
    "sectionPaddingX": {
      "type": "number",
      "default": 60
    },
    "sectionMaxWidth": {
      "type": "number",
      "default": 1200
    },
    "headingText": {
      "type": "string",
      "default": "FREE FLOW SESSION"
    },
    "headingColor": {
      "type": "string",
      "default": "#c6b36a"
    },
    "headingFontSize": {
      "type": "number",
      "default": 36
    },
    "headingFontWeight": {
      "type": "string",
      "default": "600"
    },
    "headingLineHeight": {
      "type": "number",
      "default": 1.2
    },
    "headingTextTransform": {
      "type": "string",
      "default": "uppercase"
    },
    "headingMaxWidth": {
      "type": "number",
      "default": 800
    },
    "gapBelowHeading": {
      "type": "number",
      "default": 24
    },
    "descText": {
      "type": "string",
      "default": "Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua."
    },
    "descColor": {
      "type": "string",
      "default": "#e5e5e5"
    },
    "descFontSize": {
      "type": "number",
      "default": 16
    },
    "descFontWeight": {
      "type": "string",
      "default": "400"
    },
    "descLineHeight": {
      "type": "number",
      "default": 1.5
    },
    "descMaxWidth": {
      "type": "number",
      "default": 1000
    },
    "gapBelowDesc": {
      "type": "number",
      "default": 48
    },
    "cardsGap": {
      "type": "number",
      "default": 24
    },
    "cardBorderRadius": {
      "type": "number",
      "default": 12
    },
    "cardPadding": {
      "type": "number",
      "default": 24
    },
    "cardBorderWidth": {
      "type": "number",
      "default": 1
    },
    "cardBgColor": {
      "type": "string",
      "default": "transparent"
    },
    "cardMinHeight": {
      "type": "number",
      "default": 200
    },
    "titleFontSize": {
      "type": "number",
      "default": 18
    },
    "titleFontWeight": {
      "type": "string",
      "default": "600"
    },
    "titleLineHeight": {
      "type": "number",
      "default": 1.3
    },
    "titleColor": {
      "type": "string",
      "default": "#c6b36a"
    },
    "titleMaxWidth": {
      "type": "number",
      "default": 150
    },
    "gapTitleIcon": {
      "type": "number",
      "default": 12
    },
    "titleIconSize": {
      "type": "number",
      "default": 40
    },
    "timeFontSize": {
      "type": "number",
      "default": 14
    },
    "timeFontWeight": {
      "type": "string",
      "default": "400"
    },
    "timeColor": {
      "type": "string",
      "default": "#e5e5e5"
    },
    "timeIconSize": {
      "type": "number",
      "default": 16
    },
    "gapTimeIconText": {
      "type": "number",
      "default": 8
    },
    "pointsFontSize": {
      "type": "number",
      "default": 14
    },
    "pointsFontWeight": {
      "type": "string",
      "default": "400"
    },
    "pointsLineHeight": {
      "type": "number",
      "default": 1.5
    },
    "pointsColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "gapTitleRowTimeRow": {
      "type": "number",
      "default": 16
    },
    "gapTimeRowPointsRow": {
      "type": "number",
      "default": 12
    }
  },
  "supports": {
    "align": [
      "full",
      "wide"
    ],
    "html": false,
    "className": false
  },
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}