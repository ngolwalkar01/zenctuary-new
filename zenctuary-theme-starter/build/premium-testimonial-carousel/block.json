{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "zenctuary/premium-testimonial-carousel",
  "version": "1.0.0",
  "title": "Premium Testimonial Carousel",
  "category": "design",
  "icon": "format-quote",
  "description": "A premium edge-peek testimonial carousel with text and video testimonial cards.",
  "keywords": [
    "testimonial",
    "carousel",
    "video",
    "review",
    "slider"
  ],
  "attributes": {
    "heading": {
      "type": "string",
      "default": "WHAT OUR CLIENTS SAY"
    },
    "subheading": {
      "type": "string",
      "default": ""
    },
    "contentMaxWidth": {
      "type": "number",
      "default": 1320
    },
    "backgroundColor": {
      "type": "string",
      "default": "#4b4339"
    },
    "backgroundImageId": {
      "type": "number",
      "default": 0
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "headingMaxWidth": {
      "type": "number",
      "default": 980
    },
    "headingFontSize": {
      "type": "string",
      "default": "clamp(2.1rem, 4vw, 4rem)"
    },
    "headingFontWeight": {
      "type": "string",
      "default": "700"
    },
    "headingLineHeight": {
      "type": "string",
      "default": "1"
    },
    "headingColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "sectionPadding": {
      "type": "object",
      "default": {
        "top": "72px",
        "right": "24px",
        "bottom": "72px",
        "left": "24px"
      }
    },
    "gap": {
      "type": "number",
      "default": 36
    },
    "desktopCards": {
      "type": "number",
      "default": 3
    },
    "tabletCards": {
      "type": "number",
      "default": 2
    },
    "mobileCards": {
      "type": "number",
      "default": 1
    },
    "edgePeekDesktop": {
      "type": "number",
      "default": 20
    },
    "edgePeekTablet": {
      "type": "number",
      "default": 20
    },
    "edgePeekMobile": {
      "type": "number",
      "default": 20
    },
    "leftStartOffsetDesktop": {
      "type": "number",
      "default": 80
    },
    "leftStartOffsetTablet": {
      "type": "number",
      "default": 48
    },
    "leftStartOffsetMobile": {
      "type": "number",
      "default": 20
    },
    "cardWidthScaleDesktop": {
      "type": "number",
      "default": 100
    },
    "cardWidthScaleTablet": {
      "type": "number",
      "default": 100
    },
    "cardWidthScaleMobile": {
      "type": "number",
      "default": 100
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "autoplayDelay": {
      "type": "number",
      "default": 4000
    },
    "transitionSpeed": {
      "type": "number",
      "default": 450
    },
    "showPagination": {
      "type": "boolean",
      "default": false
    },
    "cardBorderRadius": {
      "type": "number",
      "default": 24
    },
    "cardContentPadding": {
      "type": "number",
      "default": 32
    },
    "textCardBackgroundColor": {
      "type": "string",
      "default": "#4a4848"
    },
    "quoteFontSize": {
      "type": "string",
      "default": "clamp(1.35rem, 1.7vw, 1.65rem)"
    },
    "quoteFontWeight": {
      "type": "string",
      "default": "400"
    },
    "quoteLineHeight": {
      "type": "string",
      "default": "1.45"
    },
    "quoteColor": {
      "type": "string",
      "default": "#f3f0eb"
    },
    "authorFontSize": {
      "type": "string",
      "default": "1.15rem"
    },
    "authorFontWeight": {
      "type": "string",
      "default": "700"
    },
    "authorLineHeight": {
      "type": "string",
      "default": "1.2"
    },
    "authorColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "starsColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "starsSize": {
      "type": "string",
      "default": "1.95rem"
    },
    "starsLetterSpacing": {
      "type": "string",
      "default": "0.14em"
    },
    "avatarSize": {
      "type": "number",
      "default": 62
    },
    "avatarBorderColor": {
      "type": "string",
      "default": "rgba(255, 255, 255, 0.88)"
    },
    "playButtonSize": {
      "type": "number",
      "default": 82
    },
    "playButtonBackgroundColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "playButtonIconColor": {
      "type": "string",
      "default": "#3d3937"
    },
    "videoOverlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.18)"
    },
    "navButtonSize": {
      "type": "number",
      "default": 54
    },
    "navIconSize": {
      "type": "number",
      "default": 20
    },
    "navBorderWidth": {
      "type": "number",
      "default": 1
    },
    "navBorderRadius": {
      "type": "string",
      "default": "999px"
    },
    "navBorderColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "navBackgroundColor": {
      "type": "string",
      "default": "transparent"
    },
    "navIconColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "navHoverBackgroundColor": {
      "type": "string",
      "default": "#dbbf58"
    },
    "navHoverIconColor": {
      "type": "string",
      "default": "#3f3932"
    },
    "navIconSet": {
      "type": "string",
      "default": "chevron"
    },
    "cards": {
      "type": "array",
      "default": [
        {
          "cardType": "text",
          "avatarImageId": 0,
          "avatarImageUrl": "",
          "imageId": 0,
          "imageUrl": "",
          "videoId": 0,
          "rating": 5,
          "quote": "\"Lorem ipsum dolor sit amet consectetur adipiscing lectus a nunc mauris scelerisque sed egestas pharetraol quis pharetra arcu pharetra blandit amet conse ctetur adipiscing.\"",
          "authorName": "Max Mustermann",
          "videoUrl": "",
          "openInNewTab": false
        },
        {
          "cardType": "video",
          "avatarImageId": 0,
          "avatarImageUrl": "",
          "imageId": 0,
          "imageUrl": "",
          "videoId": 0,
          "rating": 5,
          "quote": "",
          "authorName": "Max Mustermann",
          "videoUrl": "#",
          "openInNewTab": false
        },
        {
          "cardType": "text",
          "avatarImageId": 0,
          "avatarImageUrl": "",
          "imageId": 0,
          "imageUrl": "",
          "videoId": 0,
          "rating": 5,
          "quote": "\"Lorem ipsum dolor sit amet consectetur adipiscing lectus a nunc mauris scelerisque sed egestas pharetraol quis pharetra arcu pharetra blandit.\"",
          "authorName": "Max Mustermann",
          "videoUrl": "",
          "openInNewTab": false
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "zenctuary",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "style": [
    "file:./index.css",
    "file:./style-index.css"
  ],
  "editorStyle": [
    "file:./index.css",
    "file:./style-index.css"
  ]
}